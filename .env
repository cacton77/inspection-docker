CONTAINER_NAME=inspection-docker
ROS_DOMAIN_ID=2
ROS_DISTRO=jazzy
# RMW: rmw_cyclonedds_cpp (default) or rmw_fastrtps_cpp.
# Fast-DDS sidesteps the "Failed to parse type hash ... USER_DATA '(null)'" noise on Jazzy.
RMW_IMPLEMENTATION=rmw_fastrtps_cpp
COMPOSE_PROFILE=linux-gpu
COMPOSE_SERVICE=linux-gpu
USE_SERVICE=false
