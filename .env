CONTAINER_NAME=inspection-docker
ROS_DOMAIN_ID=2
ROS_DISTRO=jazzy
# RMW: rmw_cyclonedds_cpp (default) or rmw_fastrtps_cpp.
# FastDDS' UDPv4 transport stalls high-bandwidth raw image streams when a
# cross-host subscriber attaches (verified: pi_camera 30 Hz × 2.7 MB frames
# halted the writer the instant pop-os subscribed; CycloneDDS at identical
# QoS sustained 30 Hz steady). Stick with CycloneDDS unless something on
# the graph specifically requires FastDDS.
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp
COMPOSE_PROFILE=linux-gpu
COMPOSE_SERVICE=linux-gpu
USE_SERVICE=false
