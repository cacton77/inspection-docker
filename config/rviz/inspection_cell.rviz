        ur_base_link:
          Value: false
        wrist_1_link:
          Value: false
        wrist_2_link:
          Value: false
        wrist_3_link:
          Value: false
      Marker Scale: 0.5
      Name: TF
      Show Arrows: false
      Show Axes: true
      Show Names: false
      Tree:
        object_frame:
          surface_normal:
            {}
          turntable_disc_link:
            turntable_base_link_inertia:
              turntable_base_link:
                planning_volume:
                  {}
                turntable_base:
                  {}
                ur5e_mount_link:
                  table_link:
                    {}
                  ur_base_link:
                    base:
                      {}
                    base_link_inertia:
                      shoulder_link:
                        upper_arm_link:
                          forearm_link:
                            wrist_1_link:
                              wrist_2_link:
                                wrist_3_link:
                                  flange:
                                    tool0:
                                      eoat_base_link:
                                        eoat_camera_link:
                                          camera_link:
                                            camera_aligned_depth_to_infra1_frame:
                                              camera_infra1_optical_frame:
                                                {}
                                            camera_color_frame:
                                              camera_color_optical_frame:
                                                {}
                                            camera_depth_frame:
                                              camera_depth_optical_frame:
                                                {}
                                            camera_infra1_frame:
                                              {}
                                            camera_infra2_frame:
                                              camera_infra2_optical_frame:
                                                {}
                                  ft_frame:
                                    {}
      Update Interval: 0
      Value: true
    - Class: moveit_rviz_plugin/PlanningScene
      Enabled: true
      Move Group Namespace: ""
      Name: PlanningScene
      Planning Scene Topic: /monitored_planning_scene
