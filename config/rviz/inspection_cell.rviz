    - Alpha: 0.5
      Angular Arrow Scale: 1
      Angular Color: 204; 204; 51
      Arrow Width: 0.25
      Class: rviz_default_plugins/TwistStamped
      Enabled: true
      Hide Small Values: false
      History Length: 1
      Linear Arrow Scale: 5
      Linear Color: 51; 204; 204
      Name: TwistStamped
      Topic:
        Depth: 5
        Durability Policy: Volatile
        Filter size: 10
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /servo_node/delta_twist_cmds
      Value: true
    - Class: rviz_default_plugins/Image
      Enabled: true
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Macro Camera
      Normalize Range: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /pi_camera/image_raw
      Value: true
    - Class: rviz_default_plugins/Camera
      Enabled: true
      Far Plane Distance: 100
      Image Rendering: background and overlay
      Name: RealSense D405
      Overlay Alpha: 0.5
      Topic:
        Depth: 1
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /camera/d405_camera/color/image_raw
      Value: true
      Visibility:
        Grid: true
        Image: true
        Macro Camera: true
        PlanningScene: true
        TF: true
        TSDF Cloud: true
        TwistStamped: true
        Value: true
      Zoom Factor: 1
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 0.09972906857728958
        Min Value: 0.010007443837821484
        Value: true
      Axis: Z
      Channel Name: intensity
      Class: rviz_default_plugins/PointCloud2
      Color: 255; 255; 255
      Color Transformer: AxisColor
      Decay Time: 0
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Max Intensity: 4096
      Min Color: 0; 0; 0
      Min Intensity: 0
      Name: TSDF Cloud
      Position Transformer: XYZ
      Selectable: true
      Size (Pixels): 10
      Size (m): 0.009999999776482582
      Style: Points
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Reliable
        Value: /tsdf_pose/fused_cloud
      Use Fixed Frame: true
      Use rainbow: true
      Value: true
    - Class: rviz_default_plugins/Image
      Enabled: false
      Max Value: 1
      Median window: 5
      Min Value: 0
      Name: Image
      Normalize Range: true
      Topic:
        Depth: 5
        Durability Policy: Volatile
        History Policy: Keep Last
        Reliability Policy: Best Effort
        Value: /tsdf_pose/depth/synthetic
      Value: false
  Enabled: true
  Global Options:
    Background Color: 255; 255; 255
    Fixed Frame: object_frame
    Frame Rate: 30
  Name: root
  Tools:
