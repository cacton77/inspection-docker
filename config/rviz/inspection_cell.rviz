        Y: -0.012397721409797668
        Z: 0.033331144601106644
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.05000000074505806
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: 0.3297930955886841
      Target Frame: object_frame
      Value: Orbit (rviz_default_plugins)
      Yaw: 0.8347495198249817
